// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  previewFeatures = ["driverAdapters", "postgresqlExtensions"]
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgres"
  url      = env("DATABASE_URL")
  extensions = [vector]
}

model Usuario {
  id            String   @db.VarChar(36) @id @default(uuid())
  nome          String   @db.VarChar(60)
  email         String   @db.VarChar(40) @unique
  senha         String   @db.VarChar(60)   // senha deve ser varchar(60)
  telefone      String   @db.VarChar(15)
  tipo          String   @default("usuario") @db.VarChar(20)
  latitude      Decimal? @db.Decimal(10, 7)
  longitude     Decimal? @db.Decimal(10, 7)
  configuracoes Json?
  resetToken    String?  @db.VarChar(100)
  resetTokenExpires DateTime?
  createdAt     DateTime @default(now())
  // Verificação de prestador (Fase 1)
  foto_perfil           String?   @db.VarChar(500)
  telefone_verificado   Boolean   @default(false)
  email_verificado      Boolean   @default(false)
  telefone_codigo_hash  String?   @db.VarChar(128)
  telefone_codigo_expira DateTime?
  email_codigo_hash     String?   @db.VarChar(128)
  email_codigo_expira   DateTime?
  publicacoes   Publicacao[]
  avistamentos  Avistamento[]
  eventos       Evento[]
  servicos      Servico[]
  agendamentos  Agendamento[]
  socialAccounts SocialAccount[]
  notificacoes  Notificacao[]
  inscricoesPush InscricaoPush[]
  denuncias     Denuncia[]
  inscricoesEvento InscricaoEvento[]
  verificacaoPrestador VerificacaoPrestador?
  @@map("usuarios")
}

model VerificacaoPrestador {
  id              String   @id @default(uuid()) @db.VarChar(36)
  usuarioId       String   @unique @db.VarChar(36)
  cpf_hash        String   @db.VarChar(128)
  cpf_ultimos4    String   @db.VarChar(4)
  doc_frente_url  String?  @db.VarChar(500)
  doc_verso_url   String?  @db.VarChar(500)
  selfie_url      String?  @db.VarChar(500)
  status          StatusVerificacaoPrestador @default(PENDENTE)
  motivo_rejeicao String?  @db.VarChar(500)
  verificado_em   DateTime?
  verificado_por  String?  @db.VarChar(36)
  criado_em       DateTime @default(now())
  atualizado_em   DateTime @updatedAt
  usuario         Usuario  @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@map("verificacoes_prestador")
}

model SocialAccount {
  id         String   @id @default(uuid()) @db.VarChar(36)
  provider   String   @db.VarChar(20)
  providerId String   @db.VarChar(128)
  email      String?  @db.VarChar(100)
  accessToken String? 
  refreshToken String?
  createdAt  DateTime @default(now())
  userId     String   @db.VarChar(36)
  usuario    Usuario  @relation(fields: [userId], references: [id])

  @@unique([provider, providerId])
  @@map("social_accounts")
}

model Publicacao {
  id                Int           @id @default(autoincrement())
  tipo              TiposPet      @default(PERDIDO)
  status            StatusPet     @default(ATIVO)
  titulo            String        @db.VarChar(100)
  descricao         String
  fotos_urls        String[]
  latitude          Decimal       @db.Decimal(10, 7)
  longitude         Decimal       @db.Decimal(10, 7)
  endereco_texto    String        @db.VarChar(100)
  bairro            String?       @db.VarChar(60)
  cidade            String?       @db.VarChar(60)
  especie           Especies 
  raca              String?       @db.VarChar(40)
  porte             Portes?   
  cor               String?       @db.VarChar(20)
  sexo              Sexos?    
  idade             Int?          @db.SmallInt
  unidadeIdade      UnidadeTempo? @default(ANOS)
  nome_pet          String?       @db.VarChar(40)
  telefone_contato  String?       @db.VarChar(15)
  recompensa        Decimal?      @db.Decimal(10, 2)
  data_evento       DateTime?     // Data que o pet se perdeu/foi encontrado
  data_publicacao   DateTime      @default(now())
  motivo_encerramento String?     @db.VarChar(255) // Motivo do encerramento da publicação
  usuario           Usuario       @relation(fields: [usuarioId], references: [id])
    usuarioId         String        @db.VarChar(36)
    avistamentos      Avistamento[]
    denuncias         Denuncia[]

    vetorBusca        Unsupported("vector(3072)")? @map("vetor_busca")

    // Campos de Resgate
    urgencia          NivelUrgencia?
    condicao_medica   String?       @db.VarChar(255)

    @@map("publicacoes")
}

model Evento {
  id                Int           @id @default(autoincrement())
  titulo            String        @db.VarChar(100)
  descricao         String
  fotos_urls        String[]
  latitude          Decimal       @db.Decimal(10, 7)
  longitude         Decimal       @db.Decimal(10, 7)
  endereco_texto    String        @db.VarChar(100)
  bairro            String?       @db.VarChar(60)
  cidade            String?       @db.VarChar(60)
  data_hora_inicio  DateTime
  data_hora_fim     DateTime?
  status            StatusEvento  @default(AGENDADO)
  capacidade_max    Int?          @db.SmallInt
  vagas_ocupadas    Int           @default(0) @db.SmallInt
  data_criacao      DateTime      @default(now())
  usuario           Usuario       @relation(fields: [usuarioId], references: [id])
  usuarioId         String        @db.VarChar(36)
  inscricoes        InscricaoEvento[]
  denuncias         Denuncia[]
  @@map("eventos")
}

model InscricaoEvento {
  id        Int      @id @default(autoincrement())
  evento    Evento   @relation(fields: [eventoId], references: [id], onDelete: Cascade)
  eventoId  Int
  usuario   Usuario  @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  usuarioId String   @db.VarChar(36)
  createdAt DateTime @default(now())

  @@unique([eventoId, usuarioId])
  @@map("inscricoes_evento")
}

model Servico {
  id                Int           @id @default(autoincrement())
  nome              String        @db.VarChar(100)
  tipo              TipoServico
  descricao         String
  fotos_urls        String[]
  telefone          String?       @db.VarChar(15)
  email             String?       @db.VarChar(100)
  link_rede_social  String?       @db.VarChar(255)
  endereco_texto    String        @db.VarChar(255)
  bairro            String?       @db.VarChar(60)
  cidade            String?       @db.VarChar(60)
  latitude          Decimal       @db.Decimal(10, 7)
  longitude         Decimal       @db.Decimal(10, 7)
  horario           String?       @db.VarChar(100) // Ex: "08:00-18:00 seg-sex, 09:00-14:00 sab"
  
  // Novos campos de Serviço e Agendamento
  valor_base        Decimal?      @db.Decimal(10, 2)
    variacoes         Json?
  especies_atendidas Especies[]
  dias_funcionamento String[]     // ["1", "2", "3", "4", "5"] -> Seg a Sex
  hora_inicio       String?       @db.VarChar(5)
  hora_fim          String?       @db.VarChar(5)
  duracao_agendamento Int?        // em minutos
  horarios_bloqueados String[]    @default([])
  capacidade_por_slot Int?        // quantos agendamentos simultâneos por slot
  vagas_disponiveis   Int?        // para hotéis/creches: null=ilimitado, 0=lotado
  atende_domicilio  Boolean       @default(false)
  taxa_domicilio    Decimal?      @db.Decimal(10, 2)

  avaliacoes        Decimal?      @db.Decimal(2, 1) // 0-5
  total_avaliacoes  Int           @default(0)
  oferece_agendamento Boolean     @default(false)
  tipo_agendamento  String?       @db.VarChar(20) // "HORARIO", "TURNO"
  publicado         Boolean       @default(false)
  data_criacao      DateTime      @default(now())
  usuario           Usuario       @relation(fields: [usuarioId], references: [id])
  usuarioId         String        @db.VarChar(36)
  agendamentos      Agendamento[]
  denuncias         Denuncia[]
  @@map("servicos")
}

model Agendamento {
  id                    Int                 @id @default(autoincrement())
  servico               Servico             @relation(fields: [servicoId], references: [id])
  servicoId             Int
  usuario               Usuario             @relation(fields: [usuarioId], references: [id])
  usuarioId             String              @db.VarChar(36)
  data_hora             DateTime
  horario_agendado      String?             @db.VarChar(5) // Para tipo HORARIO ex "09:00"
  turno_agendado        String?             @db.VarChar(20) // Para tipo TURNO ex "MANHA", "TARDE", "NOITE"
  observacao            String?             @db.VarChar(500)
  status                StatusAgendamento   @default(PENDENTE)
  forma_pagamento       FormaPagamento
  valor_simulado        Decimal             @db.Decimal(10, 2)
  atendimento_domicilio Boolean             @default(false)
  data_criacao          DateTime            @default(now())
  
  @@map("agendamentos")
}

model Avistamento {
  id               Int         @id @default(autoincrement())
  observacoes      String?
  fotos_urls       String[]
  latitude         Decimal     @db.Decimal(10, 7)
  longitude        Decimal     @db.Decimal(10, 7)
  endereco_texto   String      @db.VarChar(100)
  data_avistamento DateTime    @default(now())
  publicacao       Publicacao  @relation(fields: [publicacaoId], references: [id])
  publicacaoId     Int
  usuario          Usuario     @relation(fields: [usuarioId], references: [id])
  usuarioId        String      @db.VarChar(36)
  data_criacao     DateTime    @default(now())
  @@map("avistamentos")
}

model Denuncia {
  id           Int         @id @default(autoincrement())
  publicacaoId Int?
  publicacao   Publicacao? @relation(fields: [publicacaoId], references: [id])
  eventoId     Int?
  evento       Evento?     @relation(fields: [eventoId], references: [id])
  servicoId    Int?
  servico      Servico?    @relation(fields: [servicoId], references: [id])
  usuarioId    String?     @db.VarChar(36)
  usuario      Usuario?    @relation(fields: [usuarioId], references: [id])
  motivo       String      @db.VarChar(50)
  descricao    String?     @db.Text
  status       StatusDenuncia @default(PENDENTE)
  data_criacao DateTime    @default(now())

  @@map("denuncias")
}

enum NivelUrgencia {
  BAIXA
  MEDIA
  ALTA
}

enum TiposPet {
  PERDIDO
  ENCONTRADO
  ADOCAO
  RESGATE
}

enum StatusPet {
  ATIVO
  RESOLVIDO
  PENDENTE
  EM_ANDAMENTO
  EM_ANALISE
  RESGATADO
}

enum StatusEvento {
  AGENDADO
  EM_ANDAMENTO
  CONCLUIDO
  CANCELADO
}

enum TipoServico {
  // Novos tipos
  PET_SITTER
  DOG_WALKER
  BANHO_TOSA
  HOSPEDAGEM_CRECHE
  ADESTRADOR
  // Tipos antigos para não perder dados
  VETERINARIO
  PET_SHOP
  TREINADOR
  PASSEADOR
  HOSPEDAGEM
  GROOMING
  OUTROS
}

enum StatusAgendamento {
  PENDENTE
  CONFIRMADO
  CANCELADO
}

enum FormaPagamento {
  CARTAO
  PIX
  DINHEIRO
}

enum Especies {
  CACHORRO
  GATO
  OUTRO
}

enum Sexos {
  MACHO
  FEMEA
  INDEFINIDO
}

enum UnidadeTempo {
  ANOS
  MESES
}

enum Portes {
  PEQUENO
  MEDIO
  GRANDE
}

enum StatusDenuncia {
  PENDENTE
  EM_ANALISE
  ACEITA
  REJEITADA
}

enum StatusVerificacaoPrestador {
  NAO_SOLICITADO
  PENDENTE
  EM_ANALISE
  APROVADO
  REJEITADO
}

model Notificacao {
  id         String   @id @default(uuid()) @db.VarChar(36)
  usuarioId  String   @db.VarChar(36)
  usuario    Usuario  @relation(fields: [usuarioId], references: [id])
  titulo     String   @db.VarChar(150)
  corpo      String?
  dados      Json?
  lida       Boolean  @default(false)
  canal      String   @db.VarChar(20)
  prioridade Int?     @default(0)
  criadaEm   DateTime @default(now())
  enviadaEm  DateTime?
  entregue   Boolean  @default(false)

  @@map("notificacoes")
}

model InscricaoPush {
  id         String   @id @default(uuid()) @db.VarChar(36)
  usuarioId  String?  @db.VarChar(36)
  usuario    Usuario? @relation(fields: [usuarioId], references: [id])
  endpoint   String   @db.Text @unique
  keys       Json
  criadaEm   DateTime @default(now())

  @@map("inscricoes_push")
}



